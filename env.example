# Environment Variables for GitLab ↔ Google Sheets Sync
# Copy this file to .env and fill in your actual values

# ============================
# GitLab Settings (Required)
# ============================
GITLAB_TOKEN=your-gitlab-token-here
GITLAB_URL=https://sourcecontrol.hsenidmobile.com/api/v4/
PROJECT_ID=263

# ============================
# Google Sheets Settings (Required)
# ============================
SPREADSHEET_ID=your-google-sheet-id-here
WORKSHEET_NAME=Sheet1
SERVICE_ACCOUNT_FILE=service_account.json

# ============================
# GitLab Issue Template Settings (Optional)
# ============================
DEFAULT_ASSIGNEE=@your.email@company.com
DEFAULT_ESTIMATE=8h
DEFAULT_MILESTONE=%milestone-name
DEFAULT_DUE_DATE=
DEFAULT_LABEL=~task

# ============================
# Instructions:
# ============================
# 1. Copy this file: cp env.example .env
# 2. Edit .env with your actual values
# 3. Never commit .env to version control
# 
# How to get values:
# - GITLAB_TOKEN: GitLab → Settings → Access Tokens → Create with 'api' scope
# - SPREADSHEET_ID: From your Google Sheet URL (the long ID between /d/ and /edit)
# - SERVICE_ACCOUNT_FILE: Path to your downloaded service account JSON file 