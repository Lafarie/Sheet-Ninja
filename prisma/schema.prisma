generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  isAdmin       Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  savedConfigs  SavedConfig[]
  sessions      Session[]
  animationViews AnimationView[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SavedConfig {
  id               String           @id @default(cuid())
  userId           String
  name             String
  gitlabUrl        String
  gitlabToken      String
  spreadsheetId    String
  worksheetName    String
  serviceAccount   String?
  serviceAccountEmail String?
  columnMappings   Json?
  defaultAssignee  String?
  defaultMilestone String?
  defaultLabel     String?
  defaultEstimate  String?
  isDefault        Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  projectMappings  ProjectMapping[]
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProjectMapping {
  id          String      @id @default(cuid())
  configId    String
  projectName String
  projectId   String?
  assignee    String?
  milestone   String?
  labels      Json?
  estimate    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  config      SavedConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
}

model AnimationSettings {
  id          String   @id @default(cuid())
  isEnabled   Boolean  @default(true)
  items       Json     @default("[\"\u2764\ufe0f\", \"\ud83d\udc96\", \"\ud83d\udc95\", \"\ud83d\udc97\", \"\ud83d\udc9d\"]") // Default hearts
  itemCount   Int      @default(50)
  duration    Int      @default(3000)
  maxViewsPerUser Int  @default(5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("animation_settings")
}

model AnimationView {
  id        String   @id @default(cuid())
  userId    String
  viewCount Int      @default(0)
  lastViewAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([userId])
  @@map("animation_views")
}
