// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Hashed password for credentials login
  accounts      Account[]
  sessions      Session[]
  
  // User's saved configurations
  savedConfigs  SavedConfig[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Custom Models for GitLab Sync Configuration
model SavedConfig {
  id        String   @id @default(cuid())
  userId    String
  name      String   // User-friendly name for this config
  
  // GitLab Configuration
  gitlabUrl   String
  gitlabToken String // Encrypted
  
  // Google Sheets Configuration  
  spreadsheetId   String
  worksheetName   String
  serviceAccount  String? // Encrypted JSON
  
  // Column Mappings
  columnMappings  String? // JSON as string for SQLite
  
  // Project Mappings
  projectMappings ProjectMapping[]
  
  // Default settings
  defaultAssignee  String?
  defaultMilestone String?
  defaultLabel     String?
  defaultEstimate  String?
  
  isDefault Boolean @default(false) // Mark one config as default
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([userId])
}

model ProjectMapping {
  id           String @id @default(cuid())
  configId     String
  
  projectName  String
  projectId    String? // GitLab Project ID
  assignee     String?
  milestone    String?
  labels       String? // JSON array of label names as string for SQLite
  estimate     String?
  
  config SavedConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([configId])
}
